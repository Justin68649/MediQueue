{
  "version": 2,
  "framework": "php",
  "functions": {
    "api/**/*.php": {
      "runtime": "php-8.2"
    },
    "**.php": {
      "runtime": "php-8.2"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ],
  "buildCommand": "echo 'PHP build complete'",
  "env": {
    "DB_HOST": "@db_host",
    "DB_NAME": "@db_name",
    "DB_USER": "@db_user",
    "DB_PASS": "@db_pass",
    "APP_ENV": "production",
    "APP_URL": "@app_url"
  }
}
